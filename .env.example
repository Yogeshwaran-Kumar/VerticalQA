# Vertical QA Backend Configuration
# Copy this file to vertical-qa/backend/.env and fill in your API keys

# SoniaX ASR API Key (Required)
SONIAX_API_KEY=your_soniax_api_key_here

# OpenRouter LLM API Key (Required)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# LLM Model Configuration
LLM_MODEL=anthropic/claude-sonnet-4-5
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=512

# ASR Configuration
ASR_SAMPLE_RATE=16000
ASR_LANGUAGE=en
ASR_CONFIDENCE_GATE=0.40
ASR_DAMPEN_FACTOR=0.70

# SpeechBrain SER Configuration
SER_MODEL_SOURCE=speechbrain/emotion-recognition-wav2vec2-IEMOCAP
SER_CHUNK_DURATION_S=2.0
SER_CUSTOMER_SKEW=0.80

# Escalation Algorithm Configuration
INTENT_WEIGHT=0.65
SEMANTIC_WEIGHT=0.35
ESCALATION_LOW_THRESHOLD=0.50
ESCALATION_HIGH_THRESHOLD=0.75

# Context Fusion Configuration
WINDOW_SIZE=10
ACOUSTIC_WEIGHT_DECAY=0.85
SILENCE_THRESHOLD_MS=3000
INTERRUPTION_OVERLAP_MS=500

# Debug Mode
DEBUG=false
